# ==============================================================================
# Forge monorepo .gitignore
# Go modules + Rust (gateway/) + Python (mcp-server/) + LaTeX docs
# ==============================================================================

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ---- Editor ----
.idea/
*.iml
*.swp
*.swo
*~

# ---- Go: compiled binaries ----
# All release binaries land in dist/ per project structure
dist/

# Named 'forge' at repo root or in any module dir (core/forge, etc.)
**/forge

# Module-named binaries built in-place (go build without -o dist/)
penforge/penforge
watchforge/watchforge
watchforge/core
smeltforge/smeltforge
sparkforge/sparkforge
hearthforge/hearthforge
fluxforge/fluxcontroller
fluxforge/fluxagent

# Go test binaries and coverage output
*.test
*.out
coverage.html

# ---- Rust: build output ----
**/target/
**/*.rs.bk

# ---- Python: artifacts ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ---- LaTeX: build artifacts (do NOT ignore *.pdf — PDFs are docs) ----
*.aux
*.log
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# ---- Secrets and keys ----
*.age
.env
.env.*
!.env.example
docker-compose.override.yml

# Private / host keys (never commit)
**/*.pem
**/*.key
**/id_rsa
**/id_ed25519
**/*_ed25519
**/*_rsa
**/keys/*
!**/keys/.gitkeep
**/authorized_keys/*
!**/authorized_keys/.gitkeep

# ---- Forge runtime state ----
# If forge is run locally inside the repo
.forge/
/opt/

# ---- Claude Code and local tooling ----
.claude/
.jjstack/
# NOTE: jjstack/ (repo root dir) is NOT ignored — it contains plan history

# ---- Registry: live data files ----
registry/devs.json
registry/*.local.json

# ---- Generated / temp / local state ----
generated/
tmp/
.cache/
backups/
exports/
.gstack/
