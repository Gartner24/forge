# ---- OS / Editor ----
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml

# ---- python ----
/bin/__pycache__

# ---- Rust ----
# Root Cargo targets
/target/
# Per-crate targets (e.g. gateway/)
**/target
**/*.rs.bk

# ---- Node / scripts (if any) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Secrets / keys ----
**/.env
**/.env.*
!**/.env.example

# Private keys / host keys (never commit)
**/keys/*
!**/keys/.gitkeep
**/*.pem
**/*.key
**/id_rsa
**/id_ed25519
**/*_ed25519
**/*_rsa

# Authorized keys storage (commit only examples if needed)
**/authorized_keys/*
!**/authorized_keys/.gitkeep

# ---- Runtime state ----
**/logs/*
!**/logs/.gitkeep

# Registries that may contain real identities/keys
registry/devs.json
registry/*.local.json

# Generated artifacts (templates output, renders, etc.)
generated/
tmp/
.cache/
dist/

# ---- Backup / exports ----
backups/
exports/
.gstack/
