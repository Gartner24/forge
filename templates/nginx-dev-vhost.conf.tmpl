server {
    listen 80;
    server_name {{HOSTNAME}};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{HOSTNAME}};

    ssl_certificate     /etc/letsencrypt/live/{{WILDCARD_CERT_NAME}}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{WILDCARD_CERT_NAME}}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Frontend
    location / {
        proxy_pass http://dev-{{PROJECT}}-{{DEV}}:{{FRONTEND_PORT}};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend (optional)
    location {{BACKEND_PATH_PREFIX}} {
        proxy_pass http://dev-{{PROJECT}}-{{DEV}}:{{BACKEND_PORT}};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
